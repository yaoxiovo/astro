---
import { Icon } from "astro-icon/components";

import { umamiConfig } from "../config";
import { formatDateToYYYYMMDD } from "../utils/date-utils";
import { url, getDir, getPostUrlBySlug } from "../utils/url-utils";

interface Props {
	class: string;
	published: Date;
	updated?: Date;
	hideUpdateDate?: boolean;
	hidePublishedDate?: boolean;
	slug?: string;
}
const {
	published,
	updated,
	hideUpdateDate = false,
	hidePublishedDate = false,
	slug,
} = Astro.props;
const className = Astro.props.class;
---

<div class:list={["flex flex-wrap text-neutral-500 dark:text-neutral-400 items-center gap-4 gap-x-4 gap-y-2", className]}>
    <!-- publish date -->
    {!hidePublishedDate && (
        <div class="flex items-center">
            <div class="meta-icon">
                <Icon name="material-symbols:calendar-today-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium">{formatDateToYYYYMMDD(published)}</span>
        </div>
    )}

    <!-- update date -->
    {!hideUpdateDate && updated && updated.getTime() !== published.getTime() && (
        <div class="flex items-center">
            <div class="meta-icon"
            >
                <Icon name="material-symbols:edit-calendar-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium">{formatDateToYYYYMMDD(updated)}</span>
        </div>
    )}

    <!-- page views & visitors -->
    {slug && (
        <>
            <div class="flex items-center">
                <div class="meta-icon">
                    <Icon name="material-symbols:visibility-outline-rounded" class="text-xl"></Icon>
                </div>
                <span class="text-50 text-sm font-medium post-pageviews" 
                      id={`page-views-${slug}`}
                      data-url={getPostUrlBySlug(slug)}
                      data-umami-base-url={umamiConfig.baseUrl}
                      data-umami-share-id={umamiConfig.shareId}
                      data-umami-timezone={umamiConfig.timezone}
                >0 次</span>
            </div>
            <div class="flex items-center">
                <div class="meta-icon">
                    <Icon name="material-symbols:person" class="text-xl"></Icon>
                </div>
                <span class="text-50 text-sm font-medium post-visitors" 
                      id={`page-visitors-${slug}`}
                      data-url={getPostUrlBySlug(slug)}
                      data-umami-base-url={umamiConfig.baseUrl}
                      data-umami-share-id={umamiConfig.shareId}
                      data-umami-timezone={umamiConfig.timezone}
                >0 人</span>
            </div>
        </>
    )}
</div>

<script>
    // 全局数字动画函数
    function animateValue(obj, start, end, duration, suffix = '') {
        let startTimestamp = null;
        const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min((timestamp - startTimestamp) / duration, 1);
            obj.innerHTML = `${Math.floor(progress * (end - start) + start)} ${suffix}`;
            if (progress < 1) {
                window.requestAnimationFrame(step);
            } else {
                obj.innerHTML = `${end} ${suffix}`;
            }
        };
        window.requestAnimationFrame(step);
    }

    async function loadAllPostStats() {
        const viewElements = document.querySelectorAll('.post-pageviews');
        
        const urlMap = new Map();
        viewElements.forEach(el => {
            if (el.dataset.loaded === 'true' && el.textContent !== '0 次') return;
            const url = el.dataset.url;
            if (!urlMap.has(url)) {
                urlMap.set(url, {
                    url,
                    baseUrl: el.dataset.umamiBaseUrl,
                    shareId: el.dataset.umamiShareId,
                    timezone: el.dataset.umamiTimezone,
                    viewEls: [],
                    visitorEls: []
                });
            }
            urlMap.get(url).viewEls.push(el);
        });

        const visitorElements = document.querySelectorAll('.post-visitors');
        visitorElements.forEach(el => {
            if (el.dataset.loaded === 'true' && el.textContent !== '0 人') return;
            const url = el.dataset.url;
            if (urlMap.has(url)) {
                urlMap.get(url).visitorEls.push(el);
            }
        });

        for (const [url, data] of urlMap.entries()) {
            if (!data.baseUrl || !data.shareId || typeof window.fetchUmamiStats !== 'function') continue;
            try {
                const statsData = await window.fetchUmamiStats(data.baseUrl, data.shareId, {
                    url: url,
                    timezone: data.timezone
                });
                
                const views = (statsData.pageviews && typeof statsData.pageviews === 'object' && statsData.pageviews.value !== undefined) ? statsData.pageviews.value : (Number(statsData.pageviews) || 0);
                const visitors = (statsData.visitors && typeof statsData.visitors === 'object' && statsData.visitors.value !== undefined) ? statsData.visitors.value : (Number(statsData.visitors) || 0);
                
                data.viewEls.forEach(el => {
                    el.dataset.loaded = 'true';
                    if (statsData._fromCache) {
                        el.innerHTML = `${views} 次`;
                    } else {
                        const current = parseInt(el.textContent) || 0;
                        if (current !== views) animateValue(el, current, views, 1000, '次');
                    }
                });
                
                data.visitorEls.forEach(el => {
                    el.dataset.loaded = 'true';
                    if (statsData._fromCache) {
                        el.innerHTML = `${visitors} 人`;
                    } else {
                        const current = parseInt(el.textContent) || 0;
                        if (current !== visitors) animateValue(el, current, visitors, 1000, '人');
                    }
                });
            } catch(e) {
                console.error('Failed to load stats for', url, e);
            }
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', loadAllPostStats);
    } else {
        loadAllPostStats();
    }
    
    // 兼容 Swup 4
    document.addEventListener('swup:page:view', loadAllPostStats);
</script>
