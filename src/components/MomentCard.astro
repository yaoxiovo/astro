---
import { profileConfig, authorRoles } from '../config';
import { Icon } from 'astro-icon/components';

interface Props {
  moment: any;
  isDetail?: boolean;
}

const { moment, isDetail = false } = Astro.props;
const momentId = moment.id.replace(/\.[^/.]+$/, "");
const { data } = moment;

const author = data.author || profileConfig.name;
const roleDefaults = (authorRoles as any)[author] || {};

const avatar = data.avatar || roleDefaults.avatar || profileConfig.avatar;
const verifyType = (data.verifyType && data.verifyType !== 'none') ? data.verifyType : (roleDefaults.verifyType || 'none');
const verifySubject = data.verifySubject || roleDefaults.verifySubject || '';
const images = data.images || [];

// Calculate image grid columns
const gridCols = images.length === 1 ? 'grid-cols-1' : images.length === 2 || images.length === 4 ? 'grid-cols-2' : 'grid-cols-3';

const { Content } = await moment.render();
---

<div id={`moment-${momentId}`} class={`moment-card card-base w-full flex flex-col p-6 transition shadow-md dark:shadow-none scroll-mt-24 ${isDetail ? '' : 'hover:shadow-lg cursor-pointer'}`}>
  <!-- Pinned indicator -->
  {data.pinned && (
    <div class="flex items-center gap-2 text-xs font-bold text-[var(--text-color-light)] mb-3 ml-10">
      <Icon name="fa6-solid:thumbtack" class="w-3 h-3 text-[var(--primary)]" />
      <span>置顶动态</span>
    </div>
  )}

  <div class="flex flex-row gap-4">
    <!-- Avatar -->
    <div class="flex-shrink-0 relative group">
      <img src={avatar} alt={author} class="w-12 h-12 rounded-lg object-cover" />
      {verifyType && verifyType !== 'none' && (
        <div class={`absolute -bottom-1 -right-1 rounded-full shadow-sm cursor-help ${verifyType === 'blue' ? 'text-blue-500' : 'text-yellow-500'}`} title={verifySubject || '已认证'}>
          <svg viewBox="0 0 24 24" class="w-5 h-5" aria-label="Verified account" role="img"><g><path d="M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.998-3.918-3.998-.47 0-.92.084-1.336.25C14.818 2.415 13.51 1.5 12 1.5s-2.816.917-3.337 2.25c-.416-.165-.866-.25-1.336-.25-2.21 0-3.918 1.792-3.918 4 0 .495.084.965.238 1.4-1.273.65-2.148 2.02-2.148 3.6 0 1.46.728 2.76 1.848 3.52-.06.335-.09.68-.09 1.03 0 2.21 1.71 3.998 3.918 3.998.47 0 .92-.084 1.336-.25.52 1.333 1.817 2.25 3.337 2.25s2.816-.917 3.337-2.25c.416.165.866.25 1.336.25 2.21 0 3.918-1.792 3.918-4 0-.35-.03-.695-.09-1.03 1.12-.76 1.848-2.06 1.848-3.52z" fill="currentColor"></path><path d="M10.89 16.03L7.75 12.87l1.41-1.41 1.73 1.73 4.95-4.95 1.41 1.41-6.36 6.38z" fill="#fff"></path></g></svg>
        </div>
      )}
    </div>

    <!-- Content -->
    <div class="flex flex-col flex-grow min-w-0">
      <div class="flex items-center gap-2 mb-1 flex-wrap">
        <div class="font-bold text-lg text-[var(--primary)]">{author}</div>
        {verifyType && verifyType !== 'none' && verifySubject && (
          <div class={`text-xs px-2 py-0.5 rounded border opacity-80 cursor-default ${verifyType === 'blue' ? 'text-blue-600 border-blue-200 bg-blue-50/50 dark:text-blue-400 dark:border-blue-800 dark:bg-blue-900/30' : 'text-yellow-600 border-yellow-200 bg-yellow-50/50 dark:text-yellow-400 dark:border-yellow-800 dark:bg-yellow-900/30'}`} title={verifySubject}>
            <svg viewBox="0 0 24 24" class="inline-block w-3.5 h-3.5 mr-1 mb-0.5" aria-hidden="true"><g><path d="M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.998-3.918-3.998-.47 0-.92.084-1.336.25C14.818 2.415 13.51 1.5 12 1.5s-2.816.917-3.337 2.25c-.416-.165-.866-.25-1.336-.25-2.21 0-3.918 1.792-3.918 4 0 .495.084.965.238 1.4-1.273.65-2.148 2.02-2.148 3.6 0 1.46.728 2.76 1.848 3.52-.06.335-.09.68-.09 1.03 0 2.21 1.71 3.998 3.918 3.998.47 0 .92-.084 1.336-.25.52 1.333 1.817 2.25 3.337 2.25s2.816-.917 3.337-2.25c.416.165.866.25 1.336.25 2.21 0 3.918-1.792 3.918-4 0-.35-.03-.695-.09-1.03 1.12-.76 1.848-2.06 1.848-3.52z" fill="currentColor"></path><path d="M10.89 16.03L7.75 12.87l1.41-1.41 1.73 1.73 4.95-4.95 1.41 1.41-6.36 6.38z" fill="#fff"></path></g></svg>
            {verifySubject}
          </div>
        )}
      </div>
      
      <div class="moment-content-wrapper relative mb-3">
        <div class={`moment-content text-[var(--text-color)] text-base prose dark:prose-invert break-words transition-all duration-300 ${isDetail ? '' : 'line-clamp-6'}`}>
          <Content />
        </div>
        {!isDetail && <button class="moment-read-more text-[var(--primary)] text-sm font-bold mt-1 hidden hover:underline">展开全文</button>}
      </div>

      {images.length > 0 && (
        <div class={`grid gap-2 mb-3 max-w-[400px] ${gridCols}`}>
          {images.map((img: string, idx: number) => (
            <a href={img} data-fancybox={`moment-${momentId}`} data-caption={`Photo ${idx + 1}`} class="aspect-square w-full rounded-md overflow-hidden cursor-zoom-in">
              <img src={img} alt="Moment photo" class="w-full h-full object-cover transition-transform hover:scale-105" loading="lazy" />
            </a>
          ))}
        </div>
      )}

      <!-- Metadata (Time & Source) -->
      <div class="text-[13px] text-[var(--text-color-light)] mb-3 flex items-center gap-1.5 flex-wrap">
        <a href={`/moment/${momentId}/`} class="moment-time hover:underline" data-time={data.published.toISOString()} title={new Date(data.published).toLocaleString('zh-CN')}>
          {new Date(data.published).toLocaleDateString('zh-CN')}
        </a>
        {data.source && (
          <>
            <span>·</span>
            <span class="font-medium text-[var(--primary)] hover:underline cursor-pointer">{data.source}</span>
          </>
        )}
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-row justify-between items-center text-[var(--text-color-light)] max-w-[400px] mt-1 border-t border-black/5 dark:border-white/5 pt-3">
        <!-- Comment -->
        <a href={`/moment/${momentId}/`} aria-label="Reply" class="hover:text-[var(--primary)] hover:bg-[var(--primary)]/10 p-2 -ml-2 rounded-full transition flex items-center gap-1.5 group">
          <Icon name="fa6-regular:comment" class="w-4 h-4 group-active:scale-90 transition-transform" />
        </a>
        
        <!-- Retweet -->
        <button class="hover:text-green-500 hover:bg-green-500/10 p-2 rounded-full transition flex items-center gap-1.5 group">
          <Icon name="fa6-solid:retweet" class="w-4 h-4 group-active:scale-90 transition-transform" />
        </button>

        <!-- Like -->
        <button class="moment-like-btn hover:text-red-500 hover:bg-red-500/10 p-2 rounded-full transition flex items-center gap-1.5 group" 
                data-umami-event={`Like_${momentId}`}
                data-moment-id={momentId}>
          <Icon name="fa6-regular:heart" class="w-4 h-4 group-active:scale-90 transition-transform" />
          <span class="like-count text-xs font-medium" id={`like-count-${momentId}`}></span>
        </button>

        <!-- View Impressions -->
        <div class="moment-view-btn hover:text-blue-500 hover:bg-blue-500/10 p-2 rounded-full transition flex items-center gap-1.5 cursor-default"
             data-umami-event={`View_${momentId}`}
             data-moment-id={momentId}>
          <Icon name="fa6-solid:chart-simple" class="w-4 h-4" />
          <span class="view-count text-xs font-medium" id={`view-count-${momentId}`}></span>
        </div>

        <!-- Share -->
        <button class="moment-share-btn hover:text-[var(--primary)] hover:bg-[var(--primary)]/10 p-2 rounded-full transition flex items-center gap-1.5 group"
                data-moment-id={momentId}>
          <Icon name="fa6-solid:arrow-up-from-bracket" class="w-4 h-4 group-active:scale-90 transition-transform" />
        </button>
      </div>
    </div>
  </div>
</div>
