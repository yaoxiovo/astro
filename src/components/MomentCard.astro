---
import { profileConfig } from '../config';
import { formatDateToYYYYMMDD } from '../utils/date-utils';
import { Icon } from 'astro-icon/components';

interface Props {
  moment: any;
}

const { moment } = Astro.props;
const { data } = moment;

const author = data.author || profileConfig.name;
const avatar = data.avatar || profileConfig.avatar;
const images = data.images || [];

// Calculate image grid columns
const gridCols = images.length === 1 ? 'grid-cols-1' : images.length === 2 || images.length === 4 ? 'grid-cols-2' : 'grid-cols-3';

const { Content } = await moment.render();
---

<div class="flex flex-row gap-4 mb-8 bg-[var(--card-bg)] rounded-2xl p-6 transition shadow-md hover:shadow-lg dark:shadow-none">
  <!-- Avatar -->
  <div class="flex-shrink-0 relative group">
    <img src={avatar} alt={author} class="w-12 h-12 rounded-lg object-cover" />
    {data.verifyType && data.verifyType !== 'none' && (
      <div class={`absolute -bottom-1 -right-1 rounded-full shadow-sm cursor-help ${data.verifyType === 'blue' ? 'text-blue-500' : 'text-yellow-500'}`} title={data.verifySubject || '已认证'}>
        <svg viewBox="0 0 24 24" class="w-5 h-5" aria-label="Verified account" role="img"><g><path d="M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.998-3.918-3.998-.47 0-.92.084-1.336.25C14.818 2.415 13.51 1.5 12 1.5s-2.816.917-3.337 2.25c-.416-.165-.866-.25-1.336-.25-2.21 0-3.918 1.792-3.918 4 0 .495.084.965.238 1.4-1.273.65-2.148 2.02-2.148 3.6 0 1.46.728 2.76 1.848 3.52-.06.335-.09.68-.09 1.03 0 2.21 1.71 3.998 3.918 3.998.47 0 .92-.084 1.336-.25.52 1.333 1.817 2.25 3.337 2.25s2.816-.917 3.337-2.25c.416.165.866.25 1.336.25 2.21 0 3.918-1.792 3.918-4 0-.35-.03-.695-.09-1.03 1.12-.76 1.848-2.06 1.848-3.52z" fill="currentColor"></path><path d="M10.89 16.03L7.75 12.87l1.41-1.41 1.73 1.73 4.95-4.95 1.41 1.41-6.36 6.38z" fill="#fff"></path></g></svg>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-grow min-w-0">
    <div class="flex items-center gap-2 mb-1 flex-wrap">
      <div class="font-bold text-lg text-[var(--primary)]">{author}</div>
      {data.verifyType && data.verifyType !== 'none' && data.verifySubject && (
        <div class={`text-xs px-2 py-0.5 rounded border opacity-80 cursor-default ${data.verifyType === 'blue' ? 'text-blue-600 border-blue-200 bg-blue-50/50 dark:text-blue-400 dark:border-blue-800 dark:bg-blue-900/30' : 'text-yellow-600 border-yellow-200 bg-yellow-50/50 dark:text-yellow-400 dark:border-yellow-800 dark:bg-yellow-900/30'}`} title={data.verifySubject}>
          <svg viewBox="0 0 24 24" class="inline-block w-3.5 h-3.5 mr-1 mb-0.5" aria-hidden="true"><g><path d="M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.998-3.918-3.998-.47 0-.92.084-1.336.25C14.818 2.415 13.51 1.5 12 1.5s-2.816.917-3.337 2.25c-.416-.165-.866-.25-1.336-.25-2.21 0-3.918 1.792-3.918 4 0 .495.084.965.238 1.4-1.273.65-2.148 2.02-2.148 3.6 0 1.46.728 2.76 1.848 3.52-.06.335-.09.68-.09 1.03 0 2.21 1.71 3.998 3.918 3.998.47 0 .92-.084 1.336-.25.52 1.333 1.817 2.25 3.337 2.25s2.816-.917 3.337-2.25c.416.165.866.25 1.336.25 2.21 0 3.918-1.792 3.918-4 0-.35-.03-.695-.09-1.03 1.12-.76 1.848-2.06 1.848-3.52z" fill="currentColor"></path><path d="M10.89 16.03L7.75 12.87l1.41-1.41 1.73 1.73 4.95-4.95 1.41 1.41-6.36 6.38z" fill="#fff"></path></g></svg>
          {data.verifySubject}
        </div>
      )}
    </div>
    
    <div class="text-[var(--text-color)] text-base mb-3 prose dark:prose-invert break-words">
      <Content />
    </div>

    {images.length > 0 && (
      <div class={`grid gap-2 mb-3 max-w-[300px] ${gridCols}`}>
        {images.map((img: string) => (
          <div class="aspect-square w-full rounded-md overflow-hidden cursor-pointer">
            <img src={img} alt="Moment photo" class="w-full h-full object-cover transition-transform hover:scale-105" loading="lazy" />
          </div>
        ))}
      </div>
    )}

    <div class="flex flex-row justify-between items-center text-sm text-[var(--text-color-light)]">
      <div>
        {data.published ? new Date(data.published).toLocaleString('zh-CN', {
          year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit'
        }) : ''}
      </div>
      <div class="flex gap-4">
        <button class="hover:text-[var(--primary)] transition flex items-center gap-1">
          <Icon name="fa6-regular:heart" class="w-4 h-4" />
        </button>
        <button class="hover:text-[var(--primary)] transition flex items-center gap-1">
          <Icon name="fa6-regular:comment" class="w-4 h-4" />
        </button>
      </div>
    </div>
  </div>
</div>
