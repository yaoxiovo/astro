---
// GoogleLogin.astro
import { siteConfig } from "../config";
const clientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || siteConfig.googleClientId || "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com";
---

<!-- Google Identity Services SDK -->
<script src="https://accounts.google.com/gsi/client" async defer></script>

<script define:vars={{ clientId }}>
  // Callback function to handle the ID token credential
  function handleGoogleLogin(response) {
    try {
      // Decode JWT payload
      const base64Url = response.credential.split('.')[1];
      const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
      const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {
        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
      }).join(''));

      const payload = JSON.parse(jsonPayload);
      console.log("Google Login success:", payload);
      
      // Save user profile in localStorage
      localStorage.setItem("user_profile", JSON.stringify(payload));
      
      // Optional: alert welcome message or dispatch event
      alert("欢迎登录，" + payload.name + "！喵~");
      
      // Reload page to apply changes
      window.location.reload();
    } catch (e) {
      console.error("Failed to parse Google credential token", e);
    }
  }

  // Programmatically initialize and prompt Google One Tap
  function initGoogleOneTap() {
    if (localStorage.getItem("user_profile")) {
      console.log("User is already logged in via Google.");
      return;
    }

    const interval = setInterval(() => {
      if (window.google && window.google.accounts) {
        clearInterval(interval);
        window.google.accounts.id.initialize({
          client_id: clientId,
          callback: handleGoogleLogin,
          auto_select: false
        });
        window.google.accounts.id.prompt((notification) => {
          if (notification.isNotDisplayed() || notification.isSkippedMoment()) {
            console.log("One Tap prompt not displayed or skipped:", notification.getNotDisplayedReason() || notification.getSkippedReason());
          }
        });
      }
    }, 200);
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGoogleOneTap);
  } else {
    initGoogleOneTap();
  }

  // Swup page change compatibility: prompt again if they navigate back to home page
  document.addEventListener('swup:page:view', initGoogleOneTap);
</script>
