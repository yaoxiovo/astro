---
// PosterGenerator.astro
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  excerpt: string;
  coverImage?: string;
  author: string;
}

const { title, excerpt, coverImage, author } = Astro.props;

// 动态判断V认证主体和颜色 (不修改配置文件，直接在组件内映射)
let verifiedIconColor = "";
let verifiedEntity = "";

if (author === "瑶曦网络科技官方" || author.includes("官方")) {
  verifiedIconColor = "text-blue-500";
  verifiedEntity = "企业官方认证";
} else if (author === "瑶曦" || author === "Yaoxi") {
  verifiedIconColor = "text-yellow-500";
  verifiedEntity = "个人博主认证";
}
---

<button id="generate-poster-btn" class="group flex items-center gap-1 px-3 py-1.5 rounded bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-regular-bg-hover)] active:bg-[var(--btn-regular-bg-active)] text-[var(--btn-content)] text-xs font-medium transition-all active:scale-95">
  <Icon name="material-symbols:image-outline" class="text-[0.875rem] group-hover:scale-110 transition-transform"></Icon>
  分享海报
</button>

<!-- 隐藏的海报 DOM 结构 -->
<div id="poster-hidden-container" class="fixed top-[-9999px] left-[-9999px] w-[400px] bg-white text-black p-6 rounded-2xl shadow-2xl overflow-hidden" style="z-index: -99;">
  <div class="relative z-10">
    <!-- 封面图 -->
    {coverImage && (
      <div class="w-full h-[200px] mb-4 rounded-xl overflow-hidden">
        <img src={coverImage} class="w-full h-full object-cover" crossorigin="anonymous" id="poster-cover-img" />
      </div>
    )}
    
    <!-- 标题 -->
    <h1 class="text-2xl font-bold mb-2 leading-snug text-gray-900" style="font-family: sans-serif;">{title}</h1>
    
    <!-- 摘要 -->
    <p class="text-gray-600 text-sm leading-relaxed mb-6" style="display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;">
      {excerpt.replace(/[\n\r]+/g, ' ')}
    </p>
    
    <!-- 底部信息 -->
    <div class="flex items-center justify-between border-t border-gray-100 pt-4 mt-auto">
      <div class="flex flex-col">
        <span class="text-xs text-gray-400 mb-1">Author</span>
        <div class="flex items-center gap-1">
          <span class="text-sm font-bold text-[var(--primary)]">{author}</span>
          {verifiedEntity && (
            <div class="flex items-center gap-0.5 mt-0.5">
              <Icon name="material-symbols:verified" class={`text-[0.9rem] ${verifiedIconColor}`} />
              <span class={`text-[0.65rem] ${verifiedIconColor} font-medium`}>{verifiedEntity}</span>
            </div>
          )}
        </div>
      </div>
      
      <div class="flex flex-col items-end">
        <span class="text-xs text-gray-400 mb-1">来自博客</span>
        <span class="text-sm font-bold text-gray-800">Yaoxi Blog</span>
      </div>
    </div>
  </div>
</div>

<script is:inline src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
<script>
  function initPoster() {
    const btn = document.getElementById('generate-poster-btn');
    if (!btn) return;
    
    btn.addEventListener('click', async () => {
      const container = document.getElementById('poster-hidden-container');
      if (!container) return;
      
      const originalText = btn.innerHTML;
      btn.innerHTML = `<span class="animate-spin inline-block w-3 h-3 border-2 border-current border-t-transparent rounded-full mr-1"></span> 生成中...`;
      btn.style.pointerEvents = 'none';
      
      try {
        // 等待图片加载完成 (以防跨域缓存)
        const img = document.getElementById('poster-cover-img') as HTMLImageElement;
        if (img && !img.complete) {
          await new Promise((resolve) => {
            img.onload = resolve;
            img.onerror = resolve;
          });
        }
        
        // 渲染 Canvas
        const canvas = await (window as any).html2canvas(container, {
          scale: 2, // 高清
          useCORS: true,
          backgroundColor: '#ffffff',
          logging: false
        });
        
        // 下载图片
        const url = canvas.toDataURL('image/png');
        const a = document.createElement('a');
        a.href = url;
        a.download = `share-poster-${Date.now()}.png`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        
        // 将链接写入剪贴板
        try {
          await navigator.clipboard.writeText(window.location.href);
        } catch(e) {
          console.warn("Failed to copy url to clipboard", e);
        }
        
        // 临时修改按钮文本提示成功
        btn.innerHTML = `<span style="color: #10b981; margin-right: 0.25rem;">✔</span> 链接已复制`;
        setTimeout(() => {
          btn.innerHTML = originalText;
          btn.style.pointerEvents = 'auto';
        }, 2000);
      } catch (err) {
        console.error('Failed to generate poster', err);
        alert('海报生成失败，请重试');
        btn.innerHTML = originalText;
        btn.style.pointerEvents = 'auto';
      }
    });
  }

  initPoster();
  document.addEventListener('swup:contentReplaced', initPoster);
</script>
