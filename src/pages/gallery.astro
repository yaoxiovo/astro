---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

// 扫描 src/content/posts/photo 目录的图片
// Astro 5 中 eager glob 返回 { default: string } 对于非处理图片
const rawImages = import.meta.glob(
  '/src/content/posts/photo/*.{jpg,jpeg,png,webp,avif,gif,JPG,JPEG,PNG,WEBP}',
  { eager: true, query: '?url', import: 'default' }
) as Record<string, string>;

interface GalleryItem {
  src: string;
  title: string;
  filename: string;
}

const images: GalleryItem[] = Object.entries(rawImages).map(([filePath, src]) => {
  const filename = filePath.split('/').pop() ?? '';
  const title = filename.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ');
  return { src, title, filename };
});
---

<MainGridLayout title="相册" description="瑶曦的照片墙 — 记录生活的美好瞬间">
  <div class="card-base px-6 md:px-8 pt-6 pb-8">

    <!-- 页面标题 -->
    <div class="flex items-center gap-3 mb-6">
      <div class="h-9 w-9 rounded-xl bg-[var(--primary)] flex items-center justify-center text-white dark:text-black/70 flex-shrink-0">
        <Icon name="material-symbols:photo-library-rounded" class="text-[1.4rem]" />
      </div>
      <div>
        <h1 class="text-2xl font-bold text-black/90 dark:text-white/90">相册</h1>
        <p class="text-sm text-black/40 dark:text-white/40 mt-0.5">记录生活的美好瞬间</p>
      </div>
      <div class="ml-auto text-sm text-black/30 dark:text-white/30 bg-black/5 dark:bg-white/5 px-2.5 py-1 rounded-full">
        {images.length} 张
      </div>
    </div>

    {images.length === 0 ? (
      <!-- 空状态 -->
      <div class="flex flex-col items-center justify-center py-20 gap-4">
        <div class="w-16 h-16 rounded-2xl bg-black/5 dark:bg-white/5 flex items-center justify-center">
          <Icon name="material-symbols:add-photo-alternate-outline" class="text-[2rem] text-black/25 dark:text-white/25" />
        </div>
        <p class="text-black/40 dark:text-white/40 text-sm">相册还没有照片</p>
        <p class="text-black/25 dark:text-white/25 text-xs">
          将图片放入 <code class="font-mono bg-black/5 dark:bg-white/5 px-1 py-0.5 rounded">src/content/posts/photo/</code> 目录即可
        </p>
      </div>
    ) : (
      <!-- 瀑布流网格 -->
      <div
        id="gallery-grid"
        class="columns-2 sm:columns-3 lg:columns-4 gap-3"
        style="column-gap: 0.75rem;"
      >
        {images.map((img, i) => (
          <div
            class="gallery-item break-inside-avoid mb-3 group relative overflow-hidden rounded-xl cursor-zoom-in"
            style={`animation-delay: ${Math.min(i * 50, 500)}ms`}
          >
            <img
              src={img.src}
              alt={img.title}
              loading="lazy"
              decoding="async"
              class="w-full h-auto block transition-all duration-500 group-hover:scale-[1.04] group-hover:brightness-95"
              data-fancybox="gallery"
              data-caption={img.title}
            />
            <!-- hover 文字遮罩 -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent
                        opacity-0 group-hover:opacity-100 transition-opacity duration-300
                        flex items-end p-3 pointer-events-none">
              <span class="text-white/90 text-xs font-medium drop-shadow-sm truncate max-w-full leading-snug">
                {img.title}
              </span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</MainGridLayout>

<style is:global>
  .gallery-item {
    animation: galleryFadeIn 0.5s ease both;
  }

  @keyframes galleryFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>
