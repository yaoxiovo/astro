---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

// 扫描 /public 目录中的图片 + content/posts/photo 目录
// 由于 Astro 静态导入限制，这里直接用 import.meta.glob 扫描

const rawImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/posts/photo/*.{jpg,jpeg,png,webp,avif,gif}',
  { eager: true }
);

const images = Object.entries(rawImages).map(([path, mod]) => {
  const filename = path.split('/').pop() ?? '';
  return {
    src: mod.default.src,
    width: mod.default.width,
    height: mod.default.height,
    filename,
    // 可以通过文件名约定提取标题，如 "2024-01-my-photo.jpg" → "my photo"
    title: filename.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' '),
  };
});
---

<MainGridLayout title="相册" description="瑶曦的照片墙 — 记录生活的美好瞬间">
  <div class="card-base px-6 md:px-8 pt-6 pb-8">

    <!-- 页面标题 -->
    <div class="flex items-center gap-3 mb-6">
      <div class="h-9 w-9 rounded-xl bg-[var(--primary)] flex items-center justify-center text-white dark:text-black/70 flex-shrink-0">
        <Icon name="material-symbols:photo-library-rounded" class="text-[1.4rem]" />
      </div>
      <div>
        <h1 class="text-2xl font-bold text-black/90 dark:text-white/90">相册</h1>
        <p class="text-sm text-black/40 dark:text-white/40 mt-0.5">记录生活的美好瞬间</p>
      </div>
      <div class="ml-auto text-sm text-black/30 dark:text-white/30">
        共 {images.length} 张
      </div>
    </div>

    {images.length === 0 ? (
      <!-- 空状态 -->
      <div class="flex flex-col items-center justify-center py-20 gap-4">
        <div class="w-16 h-16 rounded-2xl bg-black/5 dark:bg-white/5 flex items-center justify-center">
          <Icon name="material-symbols:add-photo-alternate-outline" class="text-[2rem] text-black/25 dark:text-white/25" />
        </div>
        <p class="text-black/40 dark:text-white/40 text-sm">相册还没有照片</p>
        <p class="text-black/25 dark:text-white/25 text-xs">将图片放入 <code class="font-mono">src/content/posts/photo/</code> 目录即可</p>
      </div>
    ) : (
      <!-- 瀑布流网格 -->
      <div
        id="gallery-grid"
        class="columns-2 sm:columns-3 lg:columns-4 gap-3 space-y-0"
      >
        {images.map((img, i) => (
          <div
            class="gallery-item break-inside-avoid mb-3 group relative overflow-hidden rounded-xl cursor-zoom-in"
            style={`animation-delay: ${i * 40}ms`}
          >
            <!-- 实际图片 -->
            <img
              src={img.src}
              alt={img.title}
              width={img.width}
              height={img.height}
              loading="lazy"
              decoding="async"
              class="w-full h-auto block transition-transform duration-500 group-hover:scale-[1.04]"
              data-fancybox="gallery"
              data-caption={img.title}
            />
            <!-- hover 遮罩 -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-end p-3 opacity-0 group-hover:opacity-100">
              <span class="text-white/90 text-xs font-medium drop-shadow truncate max-w-full">
                {img.title}
              </span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</MainGridLayout>

<style is:global>
  .gallery-item {
    animation: galleryFadeIn 0.5s ease both;
  }

  @keyframes galleryFadeIn {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  // 使用已在 Layout.astro 中全局注册的 Fancybox
  // Fancybox 会自动处理 data-fancybox="gallery" 属性的图片
</script>
