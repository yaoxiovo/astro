---
import MainGridLayout from '../../layouts/MainGridLayout.astro';
import MomentCard from '../../components/MomentCard.astro';
import PosterGenerator from '../../components/PosterGenerator.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
    const allMoments = await getCollection('moments');
    return allMoments.map((moment) => ({
        params: { slug: moment.id.replace(/\.[^/.]+$/, "") },
        props: { moment },
    }));
}

const { moment } = Astro.props;
const allMoments = await getCollection('moments');

// Find thread: Parent -> Current -> Children
let parent = null;
if (moment.data.replyTo) {
    parent = allMoments.find(m => m.id.replace(/\.[^/.]+$/, "") === moment.data.replyTo);
}

const children = allMoments
    .filter(m => m.data.replyTo === moment.id.replace(/\.[^/.]+$/, ""))
    .sort((a, b) => new Date(a.data.published).getTime() - new Date(b.data.published).getTime());

// Other related moments (same author, not in thread)
const threadSlugs = new Set([moment.id]);
if (parent) threadSlugs.add(parent.id);
children.forEach(c => threadSlugs.add(c.id));

const relatedMoments = allMoments
    .filter(m => m.data.author === moment.data.author && !threadSlugs.has(m.id))
    .sort((a, b) => new Date(b.data.published).getTime() - new Date(a.data.published).getTime())
    .slice(0, 3);
---

<MainGridLayout title="动态详情" description="动态详情">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <!-- Back button -->
            <div class="flex items-center justify-between mb-6 pb-4 border-b border-black/5 dark:border-white/5">
                <div class="flex items-center gap-4">
                    <a href="/moments/" class="p-2 -ml-2 rounded-full hover:bg-[var(--primary)]/10 text-[var(--primary)] transition">
                        <svg viewBox="0 0 24 24" class="w-6 h-6" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"></path></svg>
                    </a>
                    <div class="text-2xl font-bold text-[var(--primary)]">动态详情 (Thread)</div>
                </div>
                <PosterGenerator 
                    title={`${moment.data.author} 的动态`}
                    excerpt={moment.body || "查看详情"}
                    author={moment.data.author}
                />
            </div>
            
            <div class="flex flex-col gap-0">
                <!-- Thread Parent -->
                {parent && (
                    <div class="relative">
                        <MomentCard moment={parent} />
                        <!-- Connecting Line -->
                        <div class="absolute left-6 top-16 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700 -z-10" style="transform: translateX(-50%); height: calc(100% + 24px);"></div>
                    </div>
                )}
                
                <!-- Main Moment -->
                <div class="relative">
                    {/* Add a subtle highlight to main moment if there's a thread */}
                    <div class={(parent || children.length > 0) ? "ring-2 ring-[var(--primary)] rounded-2xl" : ""}>
                        <MomentCard moment={moment} />
                    </div>
                    {children.length > 0 && (
                        <div class="absolute left-6 top-16 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700 -z-10" style="transform: translateX(-50%); height: calc(100% + 24px);"></div>
                    )}
                </div>

                <!-- Thread Children -->
                {children.map((child, idx) => (
                    <div class="relative mt-6">
                        <MomentCard moment={child} />
                        {idx !== children.length - 1 && (
                            <div class="absolute left-6 top-16 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700 -z-10" style="transform: translateX(-50%); height: calc(100% + 24px);"></div>
                        )}
                    </div>
                ))}
            </div>

            <!-- Other Related -->
            {relatedMoments.length > 0 && (
                <div class="mt-12 pt-8 border-t border-black/5 dark:border-white/5">
                    <div class="text-xl font-bold mb-6 text-[var(--text-color)]">该作者的其他动态</div>
                    <div class="flex flex-col gap-6">
                        {relatedMoments.map(rm => (
                            <MomentCard moment={rm} />
                        ))}
                    </div>
                </div>
            )}
        </div>
    </div>
</MainGridLayout>

<script define:vars={{ umamiConfig: (await import('../../config')).umamiConfig }}>
    // Re-use logic for moments detail page
    function timeAgo(dateString) {
        const date = new Date(dateString);
        const now = new Date();
        const diffInSeconds = Math.floor((now - date) / 1000);

        if (diffInSeconds < 60) return '刚刚';
        if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)}分钟前`;
        if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)}小时前`;
        if (diffInSeconds < 172800) return '昨天';
        if (diffInSeconds < 2592000) return `${Math.floor(diffInSeconds / 86400)}天前`;
        if (diffInSeconds < 31104000) return `${Math.floor(diffInSeconds / 2592000)}个月前`;
        return `${Math.floor(diffInSeconds / 31104000)}年前`;
    }

    function processMomentDOM() {
        document.querySelectorAll('.moment-time').forEach(el => {
            const timeStr = el.getAttribute('data-time');
            if (timeStr) el.textContent = timeAgo(timeStr);
        });

        document.querySelectorAll('.moment-content').forEach(el => {
            if (el.dataset.hashtagsProcessed) return;
            el.dataset.hashtagsProcessed = "true";
            const walk = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null, false);
            const nodesToReplace = [];
            let n;
            while (n = walk.nextNode()) {
                if (n.nodeValue.match(/#([^\s<]+)/)) nodesToReplace.push(n);
            }
            nodesToReplace.forEach(node => {
                const fragment = document.createDocumentFragment();
                const parts = node.nodeValue.split(/(#(?:[^\s<]+))/);
                parts.forEach(part => {
                    if (part.startsWith('#')) {
                        const a = document.createElement('a');
                        a.className = 'hover:underline cursor-pointer text-blue-500';
                        a.style.color = '#3b82f6';
                        a.textContent = part;
                        a.href = '/moments/tag/' + encodeURIComponent(part.substring(1)) + '/';
                        // Use Swup if available
                        a.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            if (window.swup) window.swup.navigate(a.href);
                            else window.location.href = a.href;
                        });
                        fragment.appendChild(a);
                    } else {
                        fragment.appendChild(document.createTextNode(part));
                    }
                });
                node.parentNode.replaceChild(fragment, node);
            });
        });

        document.querySelectorAll('.moment-share-btn').forEach(btn => {
            const newBtn = btn.cloneNode(true);
            btn.parentNode.replaceChild(newBtn, btn);
            newBtn.addEventListener('click', function(e) {
                const url = window.location.origin + '/moment/' + this.getAttribute('data-moment-id') + '/';
                navigator.clipboard.writeText(url).then(() => {
                    const icon = this.querySelector('svg');
                    icon.style.transform = 'scale(1.2)';
                    this.classList.add('text-green-500');
                    setTimeout(() => {
                        icon.style.transform = 'scale(1)';
                        this.classList.remove('text-green-500');
                    }, 1000);
                });
            });
        });

        document.querySelectorAll('.moment-content-wrapper').forEach(wrapper => {
            if (wrapper.dataset.foldProcessed) return;
            wrapper.dataset.foldProcessed = "true";
            const content = wrapper.querySelector('.moment-content');
            const btn = wrapper.querySelector('.moment-read-more');
            if (content.scrollHeight > content.clientHeight) {
                btn.classList.remove('hidden');
                btn.addEventListener('click', () => {
                    if (content.classList.contains('line-clamp-6')) {
                        content.classList.remove('line-clamp-6');
                        btn.textContent = '收起';
                    } else {
                        content.classList.add('line-clamp-6');
                        btn.textContent = '展开全文';
                    }
                });
            }
        });

        // 5. Rich Media Embeds (Bilibili, YouTube, NetEase)
        document.querySelectorAll('.moment-content').forEach(el => {
            if (el.dataset.mediaProcessed) return;
            el.dataset.mediaProcessed = "true";

            el.querySelectorAll('a').forEach(a => {
                const url = a.href;
                let iframeSrc = null;
                
                const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/);
                if (ytMatch) {
                    iframeSrc = `https://www.youtube.com/embed/${ytMatch[1]}`;
                }
                
                const biliMatch = url.match(/bilibili\.com\/video\/(BV[\w]+)/);
                if (biliMatch) {
                    iframeSrc = `//player.bilibili.com/player.html?bvid=${biliMatch[1]}&page=1&high_quality=1&as_wide=1&allowfullscreen=true`;
                }

                const musicMatch = url.match(/music\.163\.com\/.*id=(\d+)/);
                if (musicMatch) {
                    iframeSrc = `//music.163.com/outchain/player?type=2&id=${musicMatch[1]}&auto=0&height=66`;
                }

                if (iframeSrc) {
                    const iframe = document.createElement('iframe');
                    iframe.src = iframeSrc;
                    iframe.className = "w-full rounded-xl mt-3 shadow-sm border border-black/5 dark:border-white/5";
                    iframe.style.height = musicMatch ? '86px' : '220px';
                    iframe.allowFullscreen = true;
                    
                    if (a.parentNode.tagName === 'P' && a.parentNode.textContent.trim() === a.textContent.trim()) {
                        a.parentNode.replaceWith(iframe);
                    } else {
                        a.parentNode.insertBefore(iframe, a.nextSibling);
                    }
                }
            });
        });
    }

    async function loadMomentStats() {
        if (!umamiConfig.enable) return;

        if (!window.fetchUmamiEvents) {
            window.fetchUmamiEvents = async function(baseUrl, shareId) {
                try {
                    const tokenRes = await fetch(`${baseUrl}/api/share/${shareId}`);
                    if (!tokenRes.ok) return [];
                    const tokenData = await tokenRes.json();
                    const token = tokenData.token;
                    const websiteId = tokenData.websiteId;

                    const startAt = Date.now() - 30 * 24 * 60 * 60 * 1000;
                    const endAt = Date.now();
                    const eventsRes = await fetch(`${baseUrl}/api/websites/${websiteId}/metrics?type=event&startAt=${startAt}&endAt=${endAt}&timezone=Asia/Shanghai`, {
                        headers: { 'x-umami-share-token': token }
                    });
                    if (!eventsRes.ok) return [];
                    return await eventsRes.json();
                } catch (e) {
                    console.error("fetchUmamiEvents error", e);
                    return [];
                }
            }
        }
        try {
            const statsData = await fetchUmamiEvents(umamiConfig.baseUrl, umamiConfig.shareId, {});
            if (Array.isArray(statsData)) {
                statsData.forEach(item => {
                    if (item.x && item.x.startsWith('Like_')) {
                        const momentId = item.x.replace('Like_', '');
                        const countSpan = document.getElementById(`like-count-${momentId}`);
                        if (countSpan) {
                            const current = parseInt(countSpan.textContent) || 0;
                            if (item.y > current) countSpan.textContent = item.y;
                        }
                    } else if (item.x && item.x.startsWith('View_')) {
                        const momentId = item.x.replace('View_', '');
                        const countSpan = document.getElementById(`view-count-${momentId}`);
                        if (countSpan) {
                            countSpan.textContent = item.y;
                        }
                    }
                });
            }
        } catch (error) {
            console.error('获取统计数据失败:', error);
        }
    }

    function initLikeButtons() {
        document.querySelectorAll('.moment-like-btn').forEach(btn => {
            if (btn.dataset.likeInitialized) return;
            btn.dataset.likeInitialized = "true";
            
            const momentId = btn.dataset.momentId;
            const storageKey = `liked_moment_${momentId}`;
            
            // 恢复本地点赞状态
            if (localStorage.getItem(storageKey) === "true") {
                btn.dataset.liked = "true";
                btn.classList.add('text-red-500');
            }

            btn.addEventListener('click', function(e) {
                if (this.dataset.liked === "true") return;
                this.dataset.liked = "true";
                this.classList.add('text-red-500');
                localStorage.setItem(storageKey, "true");
                
                const span = this.querySelector('.like-count');
                if (span) {
                    const current = parseInt(span.textContent) || 0;
                    span.textContent = current + 1;
                }
                
                if (window.umami) {
                    window.umami.track(`Like_${momentId}`);
                }
                
                const icon = this.querySelector('svg');
                icon.style.transform = 'scale(1.3)';
                setTimeout(() => { icon.style.transform = 'scale(1)'; }, 200);
            });
        });
    }

    function initCardClick() {
        if (window._momentCardClickInit) return;
        window._momentCardClickInit = true;

        document.addEventListener('click', (e) => {
            const card = e.target.closest('.moment-card');
            if (!card) return;

            if (e.target.closest('a') || e.target.closest('button') || e.target.closest('.moment-view-btn') || e.target.closest('img')) {
                return;
            }
            const idAttr = card.id;
            if (!idAttr || !idAttr.startsWith('moment-')) return;
            const momentId = idAttr.replace('moment-', '');
            
            if (window.swup) {
                window.swup.navigate(`/moment/${momentId}/`);
            } else {
                window.location.href = `/moment/${momentId}/`;
            }
        });
    }

    function initAll() {
        processMomentDOM();
        initLikeButtons();
        initCardClick();
        loadMomentStats(); 
    }

    document.addEventListener('DOMContentLoaded', initAll);
    document.addEventListener('swup:page:view', initAll);
</script>
