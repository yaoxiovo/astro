---
import MainGridLayout from '../../layouts/MainGridLayout.astro';
import MomentCard from '../../components/MomentCard.astro';
import Pagination from '../../components/control/Pagination.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }) {
    const allMoments = await getCollection('moments');
    
    // Filter out replies, only show top-level moments on homepage
    const topLevelMoments = allMoments.filter((moment) => !moment.data.replyTo);

    // Sort by pinned (true first), then by date (newest first)
    const sortedMoments = topLevelMoments.sort((a, b) => {
        if (a.data.pinned && !b.data.pinned) return -1;
        if (!a.data.pinned && b.data.pinned) return 1;
        return new Date(b.data.published).getTime() - new Date(a.data.published).getTime();
    });
    // Return a paginated collection, e.g., 10 moments per page
    return paginate(sortedMoments, { pageSize: 10 });
}

const { page } = Astro.props;
---

<MainGridLayout title="朋友圈" description="我的生活瞬间与絮语">
<div class="card-base z-10 px-9 py-6 relative w-full">
        <div class="text-3xl font-bold text-[var(--primary)]">朋友圈 (Moments)</div>
    </div>
    
    <div class="mt-8">
        <!-- Publish Moment Card (Only visible to Author) -->
        <div id="publish-moment-card" class="card-base w-full p-6 mb-6 hidden border border-[var(--primary)]/20 shadow-lg transition duration-300">
            <h3 class="text-lg font-bold text-[var(--primary)] mb-3 flex items-center gap-2">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                发布新动态 (New Moment)喵~
            </h3>
            <textarea id="publish-content" placeholder="在想些什么呢，主人？支持 #标签 和换行喵..." class="w-full h-28 p-3 rounded-lg border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] text-[var(--text-color)] placeholder-black/40 dark:placeholder-white/40 resize-none text-sm mb-3"></textarea>
            
            <!-- Optional Media Link -->
            <div class="mb-3">
                <input id="publish-media" type="text" placeholder="图片链接 (选填，多张用逗号分割) 喵..." class="w-full p-2.5 rounded-lg border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] text-[var(--text-color)] placeholder-black/40 dark:placeholder-white/40 text-xs" />
            </div>
            
            <div class="flex justify-between items-center">
                <span id="publish-error" class="text-red-500 text-xs font-medium"></span>
                <button id="publish-btn" class="px-5 py-2 rounded-lg bg-[var(--primary)] hover:bg-[var(--primary)]/90 text-white font-bold text-sm shadow-md transition duration-200 hover:scale-[1.02] active:scale-[0.98]">
                    立即发表 喵！
                </button>
            </div>
        </div>

        <div id="moments-container" class="flex flex-col gap-6">
                {page.data.map((moment) => (
                    <MomentCard moment={moment} />
                ))}
                {page.data.length === 0 && (
                    <div class="text-center text-[var(--text-color-light)] py-10">
                        还没有发布过任何动态呢~
                    </div>
                )}
            </div>
            
            <!-- Infinite Scroll Trigger -->
            {page.url.next && (
                <div id="infinite-scroll-trigger" data-next-url={page.url.next} class="w-full h-10 flex items-center justify-center mt-6">
                    <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-[var(--primary)]"></div>
                </div>
            )}
            
            <!-- Standard Pagination (Fallback) -->
            <div id="standard-pagination" class={page.url.next ? "hidden" : "mt-8"}>
                <Pagination page={page} baseUrl="moments" />
            </div>
        </div>
    </div>

<script define:vars={{ umamiConfig: (await import('../../config')).umamiConfig }}>
    // Utility for relative time
    function timeAgo(dateString) {
        const date = new Date(dateString);
        const now = new Date();
        const diffInSeconds = Math.floor((now - date) / 1000);

        if (diffInSeconds < 60) return '刚刚';
        if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)}分钟前`;
        if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)}小时前`;
        if (diffInSeconds < 172800) return '昨天';
        if (diffInSeconds < 2592000) return `${Math.floor(diffInSeconds / 86400)}天前`;
        if (diffInSeconds < 31104000) return `${Math.floor(diffInSeconds / 2592000)}个月前`;
        return `${Math.floor(diffInSeconds / 31104000)}年前`;
    }

    // Process all dynamic client-side DOM updates
    function processMomentDOM() {
        // 1. Relative Time
        document.querySelectorAll('.moment-time').forEach(el => {
            const timeStr = el.getAttribute('data-time');
            if (timeStr) el.textContent = timeAgo(timeStr);
        });

        // 2. Hashtag Highlighting
        document.querySelectorAll('.moment-content').forEach(el => {
            if (el.dataset.hashtagsProcessed) return;
            el.dataset.hashtagsProcessed = "true";
            
            // Loop through text nodes directly to avoid breaking inner HTML elements like <a> or <img>
            const walk = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null, false);
            const nodesToReplace = [];
            let n;
            while (n = walk.nextNode()) {
                if (n.nodeValue.match(/#([^\s<]+)/)) {
                    nodesToReplace.push(n);
                }
            }
            nodesToReplace.forEach(node => {
                const fragment = document.createDocumentFragment();
                const parts = node.nodeValue.split(/(#(?:[^\s<]+))/);
                parts.forEach(part => {
                    if (part.startsWith('#')) {
                        const a = document.createElement('a');
                        a.className = 'hover:underline cursor-pointer text-blue-500';
                        a.style.color = '#3b82f6';
                        a.textContent = part;
                        a.href = '/moments/tag/' + encodeURIComponent(part.substring(1)) + '/';
                        // Use Swup if available
                        a.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            if (window.swup) window.swup.navigate(a.href);
                            else window.location.href = a.href;
                        });
                        fragment.appendChild(a);
                    } else {
                        fragment.appendChild(document.createTextNode(part));
                    }
                });
                node.parentNode.replaceChild(fragment, node);
            });
        });

        // 3. Share Buttons
        document.querySelectorAll('.moment-share-btn').forEach(btn => {
            const newBtn = btn.cloneNode(true);
            btn.parentNode.replaceChild(newBtn, btn);
            newBtn.addEventListener('click', function(e) {
                const url = window.location.origin + '/moment/' + this.getAttribute('data-moment-id') + '/';
                navigator.clipboard.writeText(url).then(() => {
                    const icon = this.querySelector('svg');
                    icon.style.transform = 'scale(1.2)';
                    this.classList.add('text-green-500');
                    setTimeout(() => {
                        icon.style.transform = 'scale(1)';
                        this.classList.remove('text-green-500');
                    }, 1000);
                });
            });
        });

        // 4. Read More Fold
        document.querySelectorAll('.moment-content-wrapper').forEach(wrapper => {
            if (wrapper.dataset.foldProcessed) return;
            wrapper.dataset.foldProcessed = "true";
            
            const content = wrapper.querySelector('.moment-content');
            const btn = wrapper.querySelector('.moment-read-more');
            
            // Check if content overflows
            if (content.scrollHeight > content.clientHeight) {
                btn.classList.remove('hidden');
                btn.addEventListener('click', () => {
                    if (content.classList.contains('line-clamp-6')) {
                        content.classList.remove('line-clamp-6');
                        btn.textContent = '收起';
                    } else {
                        content.classList.add('line-clamp-6');
                        btn.textContent = '展开全文';
                    }
                });
            }
        });

        // 5. Rich Media Embeds (Bilibili, YouTube, NetEase)
        document.querySelectorAll('.moment-content').forEach(el => {
            if (el.dataset.mediaProcessed) return;
            el.dataset.mediaProcessed = "true";

            el.querySelectorAll('a').forEach(a => {
                const url = a.href;
                let iframeSrc = null;
                
                const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/);
                if (ytMatch) {
                    iframeSrc = `https://www.youtube.com/embed/${ytMatch[1]}`;
                }
                
                const biliMatch = url.match(/bilibili\.com\/video\/(BV[\w]+)/);
                if (biliMatch) {
                    iframeSrc = `//player.bilibili.com/player.html?bvid=${biliMatch[1]}&page=1&high_quality=1&as_wide=1&allowfullscreen=true`;
                }

                const musicMatch = url.match(/music\.163\.com\/.*id=(\d+)/);
                if (musicMatch) {
                    iframeSrc = `//music.163.com/outchain/player?type=2&id=${musicMatch[1]}&auto=0&height=66`;
                }

                if (iframeSrc) {
                    const iframe = document.createElement('iframe');
                    iframe.src = iframeSrc;
                    iframe.className = "w-full rounded-xl mt-3 shadow-sm border border-black/5 dark:border-white/5";
                    iframe.style.height = musicMatch ? '86px' : '220px';
                    iframe.allowFullscreen = true;
                    
                    if (a.parentNode.tagName === 'P' && a.parentNode.textContent.trim() === a.textContent.trim()) {
                        a.parentNode.replaceWith(iframe);
                    } else {
                        a.parentNode.insertBefore(iframe, a.nextSibling);
                    }
                }
            });
        });
    }

    async function loadMomentStats() {
        if (!umamiConfig.enable) return;

        if (!window.fetchUmamiEvents) {
            window.fetchUmamiEvents = async function(baseUrl, shareId) {
                try {
                    const tokenRes = await fetch(`${baseUrl}/api/share/${shareId}`);
                    if (!tokenRes.ok) return [];
                    const tokenData = await tokenRes.json();
                    const token = tokenData.token;
                    const websiteId = tokenData.websiteId;

                    const startAt = Date.now() - 30 * 24 * 60 * 60 * 1000;
                    const endAt = Date.now();
                    const eventsRes = await fetch(`${baseUrl}/api/websites/${websiteId}/metrics?type=event&startAt=${startAt}&endAt=${endAt}&timezone=Asia/Shanghai`, {
                        headers: { 'x-umami-share-token': token }
                    });
                    if (!eventsRes.ok) return [];
                    return await eventsRes.json();
                } catch (e) {
                    console.error("fetchUmamiEvents error", e);
                    return [];
                }
            }
        }
        try {
            const statsData = await fetchUmamiEvents(umamiConfig.baseUrl, umamiConfig.shareId, {});
            if (Array.isArray(statsData)) {
                statsData.forEach(item => {
                    if (item.x && item.x.startsWith('Like_')) {
                        const momentId = item.x.replace('Like_', '');
                        const countSpan = document.getElementById(`like-count-${momentId}`);
                        if (countSpan) {
                            const current = parseInt(countSpan.textContent) || 0;
                            if (item.y > current) countSpan.textContent = item.y;
                        }
                    } else if (item.x && item.x.startsWith('View_')) {
                        const momentId = item.x.replace('View_', '');
                        const countSpan = document.getElementById(`view-count-${momentId}`);
                        if (countSpan) {
                            countSpan.textContent = item.y;
                        }
                    }
                });
            }
        } catch (error) {
            console.error('获取朋友圈点赞/浏览数据失败:', error);
        }
    }

    function initLikeButtons() {
        document.querySelectorAll('.moment-like-btn').forEach(btn => {
            if (btn.dataset.likeInitialized) return;
            btn.dataset.likeInitialized = "true";
            
            const momentId = btn.dataset.momentId;
            const storageKey = `liked_moment_${momentId}`;
            
            // 恢复本地点赞状态
            if (localStorage.getItem(storageKey) === "true") {
                btn.dataset.liked = "true";
                btn.classList.add('text-red-500');
            }

            btn.addEventListener('click', function(e) {
                if (this.dataset.liked === "true") return;
                this.dataset.liked = "true";
                this.classList.add('text-red-500');
                localStorage.setItem(storageKey, "true");
                
                const span = this.querySelector('.like-count');
                if (span) {
                    const current = parseInt(span.textContent) || 0;
                    span.textContent = current + 1;
                }
                
                if (window.umami) {
                    window.umami.track(`Like_${momentId}`);
                }
                
                const icon = this.querySelector('svg');
                icon.style.transform = 'scale(1.3)';
                setTimeout(() => { icon.style.transform = 'scale(1)'; }, 200);
            });
        });
    }

    function initViewTracking() {
        if (!umamiConfig.enable || !window.umami) return;
        
        const observer = new IntersectionObserver((entries, obs) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const momentId = entry.target.getAttribute('data-moment-id');
                    if (momentId) {
                        // Manually trigger a View event via Umami script API
                        window.umami.track(`View_${momentId}`);
                        obs.unobserve(entry.target); // Track only once per page load
                    }
                }
            });
        }, { threshold: 0.5 }); // Trigger when 50% of the card is visible

        document.querySelectorAll('.moment-card').forEach(card => {
            // Remove the ID prefix to get actual moment ID
            const id = card.id.replace('moment-', '');
            card.setAttribute('data-moment-id', id);
            observer.observe(card);
        });
    }

    function initCardClick() {
        // Prevent duplicate global listeners
        if (window._momentCardClickInit) return;
        window._momentCardClickInit = true;

        document.addEventListener('click', (e) => {
            const card = e.target.closest('.moment-card');
            if (!card) return;

            // Ignore if clicking interactive elements
            if (e.target.closest('a') || e.target.closest('button') || e.target.closest('.moment-view-btn') || e.target.closest('img')) {
                return;
            }

            const idAttr = card.id;
            if (!idAttr || !idAttr.startsWith('moment-')) return;
            const momentId = idAttr.replace('moment-', '');
            
            if (window.swup) {
                window.swup.navigate(`/moment/${momentId}/`);
            } else {
                window.location.href = `/moment/${momentId}/`;
            }
        });
    }

    function initInfiniteScroll() {
        const trigger = document.getElementById('infinite-scroll-trigger');
        if (!trigger) return;

        const observer = new IntersectionObserver(async (entries) => {
            if (entries[0].isIntersecting) {
                const nextUrl = trigger.getAttribute('data-next-url');
                if (!nextUrl) return;

                // Prevent multiple fetches
                if (trigger.dataset.loading === 'true') return;
                trigger.dataset.loading = 'true';

                try {
                    const res = await fetch(nextUrl);
                    const html = await res.text();
                    
                    // Parse the new HTML
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    
                    // Extract new cards
                    const newCards = doc.querySelectorAll('#moments-container .moment-card');
                    const container = document.getElementById('moments-container');
                    
                    newCards.forEach(card => {
                        container.appendChild(card);
                    });

                    // Update the trigger with the new next url
                    const newTrigger = doc.getElementById('infinite-scroll-trigger');
                    if (newTrigger && newTrigger.getAttribute('data-next-url')) {
                        trigger.setAttribute('data-next-url', newTrigger.getAttribute('data-next-url'));
                        trigger.dataset.loading = 'false';
                    } else {
                        // No more pages, hide the trigger
                        trigger.style.display = 'none';
                        const pagination = document.getElementById('standard-pagination');
                        if(pagination) pagination.classList.remove('hidden');
                        observer.disconnect();
                    }

                    // Re-process DOM for new elements (time, hashtags, read more, view tracking)
                    processMomentDOM();
                    initLikeButtons();
                    initViewTracking();
                    // loadMomentStats() relies on fetchUmamiEvents which processes everything by querying DOM again
                    loadMomentStats();

                } catch (error) {
                    console.error('Infinite scroll failed:', error);
                    trigger.dataset.loading = 'false';
                }
            }
        }, { rootMargin: '200px' }); // Trigger 200px before reaching the end

        observer.observe(trigger);
    }

    // Check publish permission for yaoxiovo@gmail.com
    function checkPublishPermission() {
        const profileStr = localStorage.getItem("user_profile");
        const card = document.getElementById("publish-moment-card");
        if (!profileStr || !card) return;
        try {
            const profile = JSON.parse(profileStr);
            if (profile.email === "yaoxiovo@gmail.com") {
                card.classList.remove("hidden");
                initPublishHandler();
            }
        } catch (e) {
            console.error("Failed to parse user profile", e);
        }
    }

    // Bind publish event
    function initPublishHandler() {
        const btn = document.getElementById("publish-btn");
        if (!btn || btn.dataset.initialized) return;
        btn.dataset.initialized = "true";

        btn.addEventListener("click", async () => {
            const contentInput = document.getElementById("publish-content");
            const mediaInput = document.getElementById("publish-media");
            const errSpan = document.getElementById("publish-error");
            
            const content = contentInput.value.trim();
            const mediaVal = mediaInput.value.trim();
            
            if (!content) {
                errSpan.textContent = "内容不能为空喵！";
                return;
            }
            
            errSpan.textContent = "";
            btn.disabled = true;
            btn.textContent = "正在发表...";
            
            const token = localStorage.getItem("google_token");
            if (!token) {
                errSpan.textContent = "未登录或登录态失效，请刷新页面重新登录喵！";
                btn.disabled = false;
                btn.textContent = "立即发表 喵！";
                return;
            }
            
            let media = [];
            if (mediaVal) {
                media = mediaVal.split(",").map(url => url.trim()).filter(url => url);
            }
            
            try {
                const res = await fetch("https://api.blog.yaoxi.wiki/api/moments", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "Authorization": `Bearer ${token}`
                    },
                    body: JSON.stringify({ content, media })
                });
                
                const data = await res.json();
                if (!res.ok) {
                    throw new Error(data.error || "发表失败");
                }
                
                // Clear input
                contentInput.value = "";
                mediaInput.value = "";
                
                // Refresh list
                await fetchMomentsFromD1();
                alert("动态发表成功，已实时载入页面喵！");
            } catch (err) {
                errSpan.textContent = err.message || "未知错误";
            } finally {
                btn.disabled = false;
                btn.textContent = "立即发表 喵！";
            }
        });
    }

    // Fetch and merge moments from D1
    async function fetchMomentsFromD1() {
        const container = document.getElementById("moments-container");
        if (!container) return;
        
        try {
            const res = await fetch("https://api.blog.yaoxi.wiki/api/moments");
            if (!res.ok) return;
            const moments = await res.json();
            if (!Array.isArray(moments)) return;
            
            // Loop in reverse order to insert newer ones at the top
            for (let i = moments.length - 1; i >= 0; i--) {
                const m = moments[i];
                const cardId = `moment-${m.id}`;
                
                // Check if already rendered
                if (document.getElementById(cardId)) continue;
                
                // Parse media JSON array
                let mediaUrls = [];
                if (m.media) {
                    try { mediaUrls = JSON.parse(m.media); } catch (e) {}
                }
                
                // Generate HTML card
                const card = document.createElement("div");
                card.id = cardId;
                card.className = "moment-card card-base w-full flex flex-col p-6 transition shadow-md dark:shadow-none scroll-mt-24 hover:shadow-lg cursor-pointer";
                
                // Pinned indicator
                let pinnedHTML = "";
                if (m.pinned) {
                    pinnedHTML = `
                        <div class="flex items-center gap-2 text-xs font-bold text-[var(--text-color-light)] mb-3 ml-10">
                          <svg viewBox="0 0 24 24" class="w-3 h-3 text-[var(--primary)] fill-current"><path d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"/></svg>
                          <span>置顶动态</span>
                        </div>
                    `;
                }
                
                // Media grid HTML
                let mediaHTML = "";
                if (mediaUrls.length > 0) {
                    const gridCols = mediaUrls.length === 1 ? 'grid-cols-1' : mediaUrls.length === 2 || mediaUrls.length === 4 ? 'grid-cols-2' : 'grid-cols-3';
                    let imgsHTML = "";
                    mediaUrls.forEach((img, idx) => {
                        imgsHTML += `
                            <a href="${img}" data-fancybox="${cardId}" data-caption="Photo ${idx + 1}" class="aspect-square w-full rounded-md overflow-hidden cursor-zoom-in">
                              <img src="${img}" alt="Moment photo" class="w-full h-full object-cover transition-transform hover:scale-105" loading="lazy" />
                            </a>
                        `;
                    });
                    mediaHTML = `<div class="grid gap-2 mb-3 max-w-[400px] ${gridCols}">${imgsHTML}</div>`;
                }
                
                // Format text content with newlines
                const escapedContent = m.content
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;")
                    .replace(/\n/g, "<br/>");
                
                const timeISO = new Date(m.published).toISOString();
                const timeLocale = new Date(m.published).toLocaleDateString('zh-CN');
                const timeFull = new Date(m.published).toLocaleString('zh-CN');
                
                card.innerHTML = `
                  \${pinnedHTML}
                  <div class="flex flex-row gap-4">
                    <!-- Avatar -->
                    <div class="flex-shrink-0 relative group">
                      <img src="https://png.yaoxi.wiki/blog.yaoxi.xyz/home.png" alt="瑶曦网络科技官方" class="w-12 h-12 rounded-lg object-cover" />
                      <!-- Blue Verification Badge -->
                      <div class="absolute -bottom-1 -right-1 rounded-full shadow-sm cursor-help text-blue-500" title="瑶曦网络科技有限公司">
                        <svg viewBox="0 0 24 24" class="w-5 h-5" aria-label="Verified account" role="img"><g><path d="M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.998-3.918-3.998-.47 0-.92.084-1.336.25C14.818 2.415 13.51 1.5 12 1.5s-2.816.917-3.337 2.25c-.416-.165-.866-.25-1.336-.25-2.21 0-3.918 1.792-3.918 4 0 .495.084.965.238 1.4-1.273.65-2.148 2.02-2.148 3.6 0 1.46.728 2.76 1.848 3.52-.06.335-.09.68-.09 1.03 0 2.21 1.71 3.998 3.918 3.998.47 0 .92-.084 1.336-.25.52 1.333 1.817 2.25 3.337 2.25s2.816-.917 3.337-2.25c.416.165.866.25 1.336.25 2.21 0 3.918-1.792 3.918-4 0-.35-.03-.695-.09-1.03 1.12-.76 1.848-2.06 1.848-3.52z" fill="currentColor"></path><path d="M10.89 16.03L7.75 12.87l1.41-1.41 1.73 1.73 4.95-4.95 1.41 1.41-6.36 6.38z" fill="#fff"></path></g></svg>
                      </div>
                    </div>
                
                    <!-- Content -->
                    <div class="flex flex-col flex-grow min-w-0">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <div class="font-bold text-lg text-[var(--primary)]">\${m.author || '瑶曦网络科技官方'}</div>
                        <div class="text-xs px-2 py-0.5 rounded border opacity-80 cursor-default text-blue-600 border-blue-200 bg-blue-50/50 dark:text-blue-400 dark:border-blue-800 dark:bg-blue-900/30" title="瑶曦网络科技有限公司">
                          <svg viewBox="0 0 24 24" class="inline-block w-3.5 h-3.5 mr-1 mb-0.5" aria-hidden="true"><g><path d="M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.998-3.918-3.998-.47 0-.92.084-1.336.25C14.818 2.415 13.51 1.5 12 1.5s-2.816.917-3.337 2.25c-.416-.165-.866-.25-1.336-.25-2.21 0-3.918 1.792-3.918 4 0 .495.084.965.238 1.4-1.273.65-2.148 2.02-2.148 3.6 0 1.46.728 2.76 1.848 3.52-.06.335-.09.68-.09 1.03 0 2.21 1.71 3.998 3.918 3.998.47 0 .92-.084 1.336-.25.52 1.333 1.817 2.25 3.337 2.25s2.816-.917 3.337-2.25c.416.165.866.25 1.336.25 2.21 0 3.918-1.792 3.918-4 0-.35-.03-.695-.09-1.03 1.12-.76 1.848-2.06 1.848-3.52z" fill="currentColor"></path><path d="M10.89 16.03L7.75 12.87l1.41-1.41 1.73 1.73 4.95-4.95 1.41 1.41-6.36 6.38z" fill="#fff"></path></g></svg>
                          瑶曦网络科技有限公司
                        </div>
                      </div>
                      
                      <div class="moment-content-wrapper relative mb-3">
                        <div class="moment-content text-[var(--text-color)] text-base prose dark:prose-invert break-words transition-all duration-300 line-clamp-6">
                          \${escapedContent}
                        </div>
                        <button class="moment-read-more text-[var(--primary)] text-sm font-bold mt-1 hidden hover:underline">展开全文</button>
                      </div>
                
                      \${mediaHTML}
                
                      <!-- Metadata -->
                      <div class="text-[13px] text-[var(--text-color-light)] mb-3 flex items-center gap-1.5 flex-wrap">
                        <a href="/moment/\${m.id}/" class="moment-time hover:underline" data-time="\${timeISO}" title="\${timeFull}">
                          \${timeLocale}
                        </a>
                      </div>
                
                      <!-- Action Buttons -->
                      <div class="flex flex-row justify-between items-center text-[var(--text-color-light)] max-w-[400px] mt-1 border-t border-black/5 dark:border-white/5 pt-3">
                        <a href="/moment/\${m.id}/" aria-label="Reply" class="hover:text-[var(--primary)] hover:bg-[var(--primary)]/10 p-2 -ml-2 rounded-full transition flex items-center gap-1.5 group">
                          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 group-active:scale-90 transition-transform"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                        </a>
                        
                        <button class="hover:text-green-500 hover:bg-green-500/10 p-2 rounded-full transition flex items-center gap-1.5 group">
                          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 group-active:scale-90 transition-transform"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                        </button>
                
                        <button class="moment-like-btn hover:text-red-500 hover:bg-red-500/10 p-2 rounded-full transition flex items-center gap-1.5 group" 
                                data-umami-event="Like_\${m.id}"
                                data-moment-id="\${m.id}">
                          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 group-active:scale-90 transition-transform"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                          <span class="like-count text-xs font-medium" id="like-count-\${m.id}"></span>
                        </button>
                
                        <div class="moment-view-btn hover:text-blue-500 hover:bg-blue-500/10 p-2 rounded-full transition flex items-center gap-1.5 cursor-default"
                             data-umami-event="View_\${m.id}"
                             data-moment-id="\${m.id}">
                          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                          <span class="view-count text-xs font-medium" id="view-count-\${m.id}"></span>
                        </div>
                
                        <button class="moment-share-btn hover:text-[var(--primary)] hover:bg-[var(--primary)]/10 p-2 rounded-full transition flex items-center gap-1.5 group"
                                data-moment-id="\${m.id}">
                          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 group-active:scale-90 transition-transform"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                        </button>
                      </div>
                    </div>
                  </div>
                `;
                
                // Insert at the beginning of moments list container
                container.insertBefore(card, container.firstChild);
            }
            
            // Reinitialize DOM processing for new elements
            processMomentDOM();
            initLikeButtons();
            initViewTracking();
            
        } catch (e) {
            console.error("Failed to fetch D1 moments", e);
        }
    }

    function initAll() {
        processMomentDOM();
        initLikeButtons();
        initViewTracking();
        initCardClick();
        initInfiniteScroll();
        loadMomentStats(); 
        checkPublishPermission();
        fetchMomentsFromD1();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAll);
    } else {
        initAll();
    }
    document.addEventListener('swup:page:view', initAll);
</script>
</MainGridLayout>
