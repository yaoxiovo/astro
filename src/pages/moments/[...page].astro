---
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import MomentCard from "../../components/MomentCard.astro";
import { getCollection } from "astro:content";
import Pagination from "../../components/control/Pagination.astro";

export async function getStaticPaths({ paginate }: { paginate: any }) {
    const allMoments = await getCollection("moments");
    
    const sortedMoments = allMoments.sort((a, b) => {
        if (a.data.pinned && !b.data.pinned) return -1;
        if (!a.data.pinned && b.data.pinned) return 1;
        return new Date(b.data.published).getTime() - new Date(a.data.published).getTime();
    });
    // Return a paginated collection, e.g., 10 moments per page
    return paginate(sortedMoments, { pageSize: 10 });
}

const { page } = Astro.props;
---

<MainGridLayout title="朋友圈" description="我的生活瞬间与絮语">
    <div class="px-4 md:px-8 mb-8 mt-4">
        <div class="text-3xl font-bold text-[var(--primary)]">朋友圈 (Moments)</div>
    </div>
    
    <div id="moments-container" class="flex flex-col gap-6">
        {page.data.map((moment) => (
            <MomentCard moment={moment} />
        ))}
        {page.data.length === 0 && (
            <div class="text-center text-[var(--text-color-light)] py-10">
                还没有发布过任何动态呢~
            </div>
        )}
    </div>
            
    <!-- Infinite Scroll Trigger -->
    {page.url.next && (
        <div id="infinite-scroll-trigger" data-next-url={page.url.next} class="w-full h-10 flex items-center justify-center mt-6">
            <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-[var(--primary)]"></div>
        </div>
    )}
            
    <!-- Standard Pagination (Fallback) -->
    <div id="standard-pagination" class={page.url.next ? "hidden" : "mt-8"}>
        <Pagination page={page} baseUrl="moments" />
    </div>

<script define:vars={{ umamiConfig: (await import('../../config')).umamiConfig }}>
    // Utility for relative time
    function timeAgo(dateString) {
        const date = new Date(dateString);
        const now = new Date();
        const diffInSeconds = Math.floor((now - date) / 1000);

        if (diffInSeconds < 60) {
            return '刚刚';
        } else if (diffInSeconds < 3600) {
            return `${Math.floor(diffInSeconds / 60)} 分钟前`;
        } else if (diffInSeconds < 86400) {
            return `${Math.floor(diffInSeconds / 3600)} 小时前`;
        } else if (diffInSeconds < 2592000) {
            return `${Math.floor(diffInSeconds / 86400)} 天前`;
        } else if (diffInSeconds < 31536000) {
            return `${Math.floor(diffInSeconds / 2592000)} 个月前`;
        } else {
            return `${Math.floor(diffInSeconds / 31536000)} 年前`;
        }
    }

    // Process DOM for moments
    function processMomentDOM() {
        // Update relative times
        document.querySelectorAll('.moment-time').forEach((el) => {
            const rawDate = el.getAttribute('data-raw-date');
            if (rawDate) {
                el.textContent = timeAgo(rawDate);
                el.classList.add('opacity-100');
            }
        });

        // Process content to make hashtags clickable
        document.querySelectorAll('.moment-content').forEach((contentEl) => {
            if (!contentEl.getAttribute('data-processed')) {
                // Find all text nodes or elements that might contain hashtags
                // We use a simple regex to find #tags, being careful not to mess up existing HTML
                const processNode = (node) => {
                    if (node.nodeType === 3) { // Text node
                        const text = node.nodeValue;
                        const regex = /(^|\s)#([\w\u4e00-\u9fa5]+)/g;
                        if (regex.test(text)) {
                            const span = document.createElement('span');
                            span.innerHTML = text.replace(regex, '$1<a href="/moments/tag/$2/" class="text-[var(--primary)] hover:underline">#$2</a>');
                            node.parentNode.replaceChild(span, node);
                        }
                    } else if (node.nodeType === 1 && node.tagName !== 'A' && node.tagName !== 'CODE' && node.tagName !== 'PRE') {
                        // Element node, but not A, CODE, or PRE (don't process inside links or code blocks)
                        Array.from(node.childNodes).forEach(processNode);
                    }
                };

                processNode(contentEl);
                contentEl.setAttribute('data-processed', 'true');
            }
        });

        // Add "Read More" functionality for long content
        document.querySelectorAll('.moment-content-wrapper').forEach((wrapper) => {
            const content = wrapper.querySelector('.moment-content');
            const readMoreBtn = wrapper.querySelector('.moment-read-more');
            
            if (content && readMoreBtn) {
                // Check if content overflows its container
                // 144px is roughly 6 lines at 24px line-height (text-base leading-6)
                // Use a slight buffer (150px) to prevent borderline cases
                if (content.scrollHeight > 150) {
                    readMoreBtn.classList.remove('hidden');
                    
                    readMoreBtn.addEventListener('click', (e) => {
                        e.stopPropagation(); // Prevent card click
                        
                        if (content.classList.contains('line-clamp-6')) {
                            content.classList.remove('line-clamp-6');
                            readMoreBtn.textContent = '收起全文';
                        } else {
                            content.classList.add('line-clamp-6');
                            readMoreBtn.textContent = '展开全文';
                            // Scroll back slightly if needed
                            const rect = wrapper.getBoundingClientRect();
                            if (rect.top < 0) {
                                window.scrollBy({ top: rect.top - 100, behavior: 'smooth' });
                            }
                        }
                    });
                }
            }
        });
    }

    // Initialize like buttons via Umami Events API
    function initLikeButtons() {
        const websiteId = umamiConfig.websiteId;
        if (!websiteId) return;

        document.querySelectorAll('.moment-like-btn').forEach(btn => {
            // Remove old listeners by cloning
            const newBtn = btn.cloneNode(true);
            btn.parentNode.replaceChild(newBtn, btn);
            
            newBtn.addEventListener('click', async (e) => {
                e.stopPropagation(); // Prevent card click
                
                const momentId = newBtn.getAttribute('data-moment-id');
                const isLiked = localStorage.getItem(`liked_moment_${momentId}`);
                
                if (isLiked) {
                    // Already liked, visual feedback
                    newBtn.classList.add('text-red-500', 'scale-125');
                    setTimeout(() => newBtn.classList.remove('scale-125'), 200);
                    return;
                }
                
                // Visual feedback immediately
                const heartIcon = newBtn.querySelector('svg');
                if (heartIcon) heartIcon.setAttribute('fill', 'currentColor');
                newBtn.classList.add('text-red-500', 'scale-125');
                setTimeout(() => newBtn.classList.remove('scale-125'), 200);
                
                // Optimistic UI update
                const countEl = document.getElementById(`like-count-${momentId}`);
                if (countEl) {
                    const currentVal = parseInt(countEl.textContent) || 0;
                    countEl.textContent = (currentVal + 1).toString();
                }
                
                // Save to local storage
                localStorage.setItem(`liked_moment_${momentId}`, 'true');
                
                // Send event to Umami
                if (typeof umami !== 'undefined' && umami.track) {
                    umami.track('Like Moment', { momentId: momentId });
                }
            });
        });
    }

    // Initialize view tracking
    function initViewTracking() {
        // Track moment views using IntersectionObserver
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const momentId = entry.target.getAttribute('data-moment-id');
                    const hasViewed = sessionStorage.getItem(`viewed_moment_${momentId}`);
                    
                    if (!hasViewed) {
                        sessionStorage.setItem(`viewed_moment_${momentId}`, 'true');
                        
                        // Send view event to Umami
                        if (typeof umami !== 'undefined' && umami.track) {
                            umami.track('View Moment', { momentId: momentId });
                        }
                    }
                    
                    // Stop observing once viewed
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 }); // Require 50% visibility

        document.querySelectorAll('.moment-card').forEach(card => {
            const momentId = card.id.replace('moment-', '');
            card.setAttribute('data-moment-id', momentId);
            observer.observe(card);
        });
    }
    
    // Load Stats from Umami API (Note: In a real app, this should be done server-side or via a secure proxy)
    // Here we simulate it or fetch from a proxy endpoint if available
    async function loadMomentStats() {
        const useUmamiData = umamiConfig.useUmamiData;
        if (!useUmamiData) return;
        
        try {
            // First try to fetch from our local proxy endpoint
            const response = await fetch('/api/umami-events');
            
            if (response.ok) {
                const eventData = await response.json();
                
                // Process the raw event data to group by momentId
                const stats = {};
                
                // Need to parse the events structure based on what Umami returns
                // This is a simplified handler
                if (Array.isArray(eventData)) {
                    eventData.forEach(event => {
                        if (event.event_name === 'Like Moment' && event.event_data && event.event_data.momentId) {
                            const id = event.event_data.momentId;
                            if (!stats[id]) stats[id] = { likes: 0, views: 0 };
                            stats[id].likes++;
                        } else if (event.event_name === 'View Moment' && event.event_data && event.event_data.momentId) {
                            const id = event.event_data.momentId;
                            if (!stats[id]) stats[id] = { likes: 0, views: 0 };
                            stats[id].views++;
                        }
                    });
                    
                    // Update DOM
                    Object.keys(stats).forEach(momentId => {
                        const likeEl = document.getElementById(`like-count-${momentId}`);
                        const viewEl = document.getElementById(`view-count-${momentId}`);
                        
                        if (likeEl && stats[momentId].likes > 0) {
                            // Check if local storage says we already liked it to prevent counting twice visually
                            const localLiked = localStorage.getItem(`liked_moment_${momentId}`);
                            const currentVal = parseInt(likeEl.textContent) || 0;
                            // Update only if DB value is higher (very simple resolution)
                            if (stats[momentId].likes > currentVal && !localLiked) {
                                likeEl.textContent = stats[momentId].likes;
                            }
                        }
                        
                        if (viewEl && stats[momentId].views > 0) {
                            viewEl.textContent = stats[momentId].views;
                        }
                    });
                }
            } else {
                console.warn("Umami events API returned:", response.status);
            }
        } catch (error) {
            console.error("Failed to load moment stats:", error);
        }
        
        // Also apply local state (e.g., liked state)
        document.querySelectorAll('.moment-like-btn').forEach(btn => {
            const momentId = btn.getAttribute('data-moment-id');
            if (localStorage.getItem(`liked_moment_${momentId}`)) {
                const heartIcon = btn.querySelector('svg');
                if (heartIcon) heartIcon.setAttribute('fill', 'currentColor');
                btn.classList.add('text-red-500');
            }
        });
    }

    function initCardClick() {
        document.querySelectorAll('.moment-card').forEach(card => {
            // Remove old listeners
            const newCard = card.cloneNode(true);
            card.parentNode.replaceChild(newCard, card);
            
            newCard.addEventListener('click', (e) => {
                // Prevent navigation if clicking on a link, button, or image
                const target = e.target;
                if (target.tagName === 'A' || target.closest('a') || 
                    target.tagName === 'BUTTON' || target.closest('button') ||
                    target.tagName === 'IMG' ||
                    target.classList.contains('moment-like-btn') || 
                    target.closest('.moment-like-btn')) {
                    return;
                }
                
                const momentId = newCard.id.replace('moment-', '');
                // Go to detail page
                if (window.swup) {
                    window.swup.navigate(`/moment/${momentId}/`);
                } else {
                    window.location.href = `/moment/${momentId}/`;
                }
            });
        });
    }

    // Infinite Scroll Implementation
    function initInfiniteScroll() {
        const trigger = document.getElementById('infinite-scroll-trigger');
        const container = document.getElementById('moments-container');
        const pagination = document.getElementById('standard-pagination');
        
        if (!trigger || !container) return;
        
        // Hide standard pagination since we use infinite scroll
        if (pagination) pagination.classList.add('hidden');

        const observer = new IntersectionObserver(async (entries) => {
            const entry = entries[0];
            if (entry.isIntersecting && trigger.dataset.nextUrl && trigger.dataset.loading !== 'true') {
                trigger.dataset.loading = 'true';
                
                try {
                    const response = await fetch(trigger.dataset.nextUrl);
                    const htmlText = await response.text();
                    
                    // Parse the new HTML
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(htmlText, 'text/html');
                    
                    // Get new moments
                    const newMoments = doc.querySelectorAll('#moments-container .moment-card');
                    
                    // Append them
                    newMoments.forEach(moment => {
                        container.appendChild(moment);
                    });
                    
                    // Re-initialize click handlers for new cards
                    initCardClick();
                    
                    // Update next URL
                    const newTrigger = doc.getElementById('infinite-scroll-trigger');
                    if (newTrigger && newTrigger.dataset.nextUrl) {
                        trigger.dataset.nextUrl = newTrigger.dataset.nextUrl;
                        trigger.dataset.loading = 'false';
                    } else {
                        // No more pages
                        trigger.remove();
                    }

                    // Re-process DOM for new elements (time, hashtags, read more, view tracking)
                    processMomentDOM();
                    initLikeButtons();
                    initViewTracking();
                    // loadMomentStats() relies on fetchUmamiEvents which processes everything by querying DOM again
                    loadMomentStats();

                } catch (error) {
                    console.error('Infinite scroll failed:', error);
                    trigger.dataset.loading = 'false';
                }
            }
        }, { rootMargin: '200px' }); // Trigger 200px before reaching the end

        observer.observe(trigger);
    }

    function initAll() {
        processMomentDOM();
        initLikeButtons();
        initViewTracking();
        initCardClick();
        initInfiniteScroll();
        loadMomentStats(); 
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAll);
    } else {
        initAll();
    }
    document.addEventListener('swup:page:view', initAll);
</script>
</MainGridLayout>
